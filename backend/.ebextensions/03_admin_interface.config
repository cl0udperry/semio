files:
  "/opt/elasticbeanstalk/hooks/appdeploy/post/start_admin_interface.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      cd /var/app/current
      nohup python web_admin_interface.py --host 0.0.0.0 --port 5001 > /var/log/admin_interface.log 2>&1 &
      echo "Admin interface started on port 5001"

container_commands:
  01_start_admin_interface:
    command: "/opt/elasticbeanstalk/hooks/appdeploy/post/start_admin_interface.sh"
